{
  "manifest_version": 3,
  "name": "MyTab Portal",
  "version": "0.3.0",
  "description": "iTab-inspired new tab page with configurable multi-portal hot cards.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://r.jina.ai/*",
    "https://www.v2ex.com/*",
    "https://www.huxiu.com/*",
    "https://36kr.com/*",
    "https://www.ithome.com/*",
    "https://www.thepaper.cn/*",
    "https://www.cls.cn/*"
  ]
}
